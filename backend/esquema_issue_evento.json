        "title": { "type": "string" },
        "content": { "type": "array", "items": { "type": "string" } },
        "text": { "type": "string" },
        "list": {
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "checked": { "type": "boolean" },
              "text": { "type": "string" }
            },
            "required": ["checked", "text"]
          }
        }
      },
      "required": ["title", "content", "text"]
    },
    "se-marcou-outros-especifique": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "array", "items": { "type": "string" } },
        "text": { "type": "string" }
      },
      "required": ["title", "content", "text"]
    }
