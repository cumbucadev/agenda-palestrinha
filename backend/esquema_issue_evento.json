        }
      },
      "required": ["title", "content", "text"]
    },
    "dia-do-ultimo-dia-de-evento": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": {
          "type": "array",
          "items": { "type": "string" }
        },
        "text": { "type": "string", "pattern": "^(0[1-9]|[12][0-9]|3[01])$" }
      },
      "required": ["title", "content", "text"]
    },
    "ano-do-primeiro-dia-de-submissao": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": {
          "type": "array",
          "items": { "type": "string" }
        },
        "text": { "type": "string", "pattern": "^[0-9]{4}$" }
      },
      "required": ["title", "content", "text"]
    },
    "mes-do-primeiro-dia-de-submissao": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": {
          "type": "array",
          "items": { "type": "string" }
        },
        "text": {
          "type": "string",
          "enum": [
            "Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho",
            "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"
          ]
        }
      },
      "required": ["title", "content", "text"]
    },
    "dia-do-primeiro-dia-de-submissao": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": {
          "type": "array",
          "items": { "type": "string" }
        },
        "text": { "type": "string", "pattern": "^(0[1-9]|[12][0-9]|3[01])$" }
      },
      "required": ["title", "content", "text"]
    },
    "ano-do-ultimo-dia-de-submissao": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": {
          "type": "array",
          "items": { "type": "string" }
        },
        "text": { "type": "string", "pattern": "^[0-9]{4}$" }
      },
      "required": ["title", "content", "text"]
    },
    "mes-do-ultimo-dia-de-submissao": {
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": {
          "type": "array",
          "items": { "type": "string" }
        },
        "text": {
          "type": "string",
          "enum": [
            "Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho",
