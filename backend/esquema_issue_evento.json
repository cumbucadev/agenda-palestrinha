      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": {
          "type": "array",
          "items": { "type": "string" }
        },
        "text": {
          "type": "string",
          "enum": [
            "Janeiro", "Fevereiro", "Março", "Abril", "Maio", "Junho",
            "Julho", "Agosto", "Setembro", "Outubro", "Novembro", "Dezembro"
